{
  "name": "@stockhawk/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings src",
    "lint:check": "pnpm lint",
    "migrate": "tsx src/migrate.ts",
    "test": "vitest run --exclude 'src/**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
